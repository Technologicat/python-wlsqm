\begin_layout Itemize
To bootstrap, we solve a steady-state potential flow problem, 
\begin_inset Formula $\boldsymbol{u}=\nabla\phi$
\end_inset

, with 
\begin_inset Formula $\nabla\cdot\nabla\phi=0$
\end_inset

.
 We can use WLSQM via the heat equation:
\begin_inset Formula 
\[
\frac{\partial\phi}{\partial t}+\nabla\cdot\nabla\phi=0
\]

\end_inset


\end_layout

\begin_layout Itemize
At all outer boundaries of the domain, use the free-stream BC: 
\begin_inset Formula $\widehat{\boldsymbol{n}}\cdot\boldsymbol{u}=\widehat{\boldsymbol{n}}\cdot\nabla\phi=\widehat{\boldsymbol{n}}\cdot\boldsymbol{u}_{\infty}$
\end_inset

.
\end_layout

\begin_deeper
\begin_layout Itemize
