\begin_inset Formula $u_{x}=u_{\infty}$
\end_inset

; at top and bottom, 
\begin_inset Formula $u_{y}=0$
\end_inset

.
\end_layout

\begin_layout Itemize
But we actually must prescribe 
\begin_inset Formula $\partial\phi/\partial n$
\end_inset

.
 The outer edges are aligned with the coordinate axes, so just use 
\begin_inset Formula $\partial\phi/\partial x=u_{\infty}$
\end_inset

 (left and right); 
\begin_inset Formula $\partial\phi/\partial y=0$
\end_inset

 (top and bottom).
\end_layout

\begin_layout Itemize
At the boundary, leave 
\begin_inset Formula $\phi$
\end_inset

 as unknown and let WLSQM compute its value.
\end_layout

\end_deeper
